<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >
    <xacro:include filename="$(find bot_description)/urdf/bot/common_inertia.xacro"/>
    <xacro:macro name="wheel_xacro" params="wheel_name xyz">
        <!-- 机器人的轮子 -->
        <link name="${wheel_name}_link">
            <!-- 部件的外观描述 -->
            <visual>
                <!-- 沿着自己几何中心的偏移和旋转量 -->
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <!-- 几何形状 -->
                <geometry> 
                    <cylinder radius="0.060" length="0.03"/>
                </geometry>
                <!-- 材质颜色 -->
                <material name="black"> 
                    <color rgba="0.0 0.0 0.0 1.0"/>
                </material>
            </visual>
            <collision>
               <!-- 沿着自己几何中心的偏移和旋转量 -->
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <!-- 几何形状 -->
                <geometry> 
                    <cylinder radius="0.060" length="0.03"/>
                </geometry>
                <!-- 材质颜色 -->
                <material name="black"> 
                    <color rgba="0.0 0.0 0.0 1.0"/>
                </material>
            </collision>
            <xacro:cylinder_inertia m="0.05" r="0.060" h="0.03" />
        </link>

        <!-- 机器人的关节，用于组合机器人的部件 -->
        <joint name="${wheel_name}_joint" type="continuous">
            <origin xyz="${xyz}" rpy="0.0 0.0 0.0"/>
            <parent link="base_link"/>
            <child link="${wheel_name}_link"/>
            <axis xyz="0.0 1.0 0.0"/>
        </joint>

        <gazebo reference='${wheel_name}_link'>
            <material>Gazebo/Black</material>
        </gazebo>
        
        <!-- mu1静,mu2动，kp 刚度系数 kd 阻尼系数 -->
        <gazebo reference="${wheel_name}_link">
            <mu1>0.0</mu1>
            <mu2>0.0</mu2>
            <kp>20000.0</kp>
            <kd>10.0</kd>
            <minDepth>0.001</minDepth>
            <maxVel>100.0</maxVel>
        </gazebo>

    </xacro:macro>
    
</robot>